{
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "exclude": [".svelte-kit", "src-tauri"],
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "include": ["src/", "*.ts", "*.js", "*.svelte"]
  },
  "tasks": {
    "dev": "deno run -A npm:vite dev",
    "main": "deno run --watch main.ts",
    "tauri:dev": "deno run -A npm:@tauri-apps/cli@2 dev",
    "lint": "deno lint",
    "lint:fix": "deno lint --fix"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
